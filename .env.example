# ---- LLM provider ----
# "anthropic" (Claude) or "gemini" (Google, free tier)
LLM_PROVIDER=gemini
# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Gemini (if LLM_PROVIDER=gemini) — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# ---- Embeddings (Voyage AI) ----
# voyage-law-2 is the legal-domain embedding model used for the corpus
VOYAGE_API_KEY=pa-xxxxxxxx

# ---- Vector store ----
# "local" = zero-infra file store (default; no Qdrant/Docker needed).
# "qdrant" = production vector DB (then fill QDRANT_* below).
VECTOR_STORE=local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kyr_legal

# ---- PostgreSQL (Prisma) ----
DATABASE_URL=postgresql://kyr:kyr@localhost:5432/kyr?schema=public

# ---- Redis (rate-limit / cache / queue) ----
REDIS_URL=redis://localhost:6379

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- App ----
NODE_ENV=development
