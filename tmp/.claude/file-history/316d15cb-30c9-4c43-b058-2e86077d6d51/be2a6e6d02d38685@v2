def clean(s):
    if s is None:
        return ""
    s = str(s)
    repl = {
        "—": "-", "–": "-", "‒": "-", "−": "-",
        "‘": "'", "’": "'", "“": '"', "”": '"',
        "…": "...", "•": "-", " ": " ", "€": "EUR ",
        "é": "e", "ü": "u", "ö": "o", "ä": "a",
        "á": "a", "í": "i", "ó": "o", "è": "e", "ç": "c",
    }
    for k, val in repl.items():
        s = s.replace(k, val)
    s = re.sub(r"�(?=\s*\d)", "EUR ", s)
    s = s.replace("�", "-")
    s = "".join(ch if ord(ch) < 256 else "?" for ch in s)
    return s

