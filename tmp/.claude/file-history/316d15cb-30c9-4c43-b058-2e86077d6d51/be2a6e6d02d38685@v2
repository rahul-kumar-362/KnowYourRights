# ---------------------------------------------------------------- PDF class
class PDF(FPDF):
    DARK = (15, 23, 42); GOLD = (212, 175, 55); GOLDL = (255, 215, 80)
    WHITE = (255, 255, 255); LIGHT = (245, 247, 250); SECT = (30, 41, 59)
    TXT = (30, 30, 30); MID = (90, 100, 120); GREEN = (34, 197, 94)
    RED = (239, 68, 68); BLUE = (59, 130, 246); GREY = (120, 120, 130)

    PRI = {"Essential": (212, 175, 55), "Recommended": (59, 130, 246), "Optional": (140, 145, 155)}

    def header(self):
        if self.page_no() == 1:
            return
        self.set_fill_color(*self.DARK); self.rect(0, 0, 210, 11, "F")
        self.set_font("Helvetica", "B", 8); self.set_text_color(*self.GOLD)
        self.set_xy(0, 3)
        self.cell(210, 5, "SCRODINGER -- PERSONALISED CHESS CURRICULUM", align="C")
        self.set_text_color(*self.TXT)

    def footer(self):
        if self.page_no() == 1:
            return
        self.set_y(-11); self.set_fill_color(*self.DARK); self.rect(0, self.get_y(), 210, 11, "F")
        self.set_font("Helvetica", "", 7); self.set_text_color(*self.GOLD)
        self.cell(0, 7, "Page " + str(self.page_no()) + "  |  Curated from 12-stream web research, June 2026", align="C")
        self.set_text_color(*self.TXT)

    def h1(self, t):
        self.ln(3); self.set_font("Helvetica", "B", 19); self.set_text_color(*self.GOLD)
        self.cell(0, 10, t, new_x=XPos.LMARGIN, new_y=YPos.NEXT)
        self.set_draw_color(*self.GOLD); self.set_line_width(0.6)
        self.line(self.l_margin, self.get_y(), 210 - self.r_margin, self.get_y())
        self.ln(3); self.set_text_color(*self.TXT)

    def h2(self, t, color=None):
        color = color or self.SECT; self.ln(2); y = self.get_y()
        if y > 250:
            self.add_page(); y = self.get_y()
        self.set_fill_color(*color); self.rect(self.l_margin, y, 190, 8, "F")
        self.set_font("Helvetica", "B", 11); self.set_text_color(*self.WHITE)
        self.set_xy(self.l_margin + 3, y + 1)
        self.cell(0, 6, t, new_x=XPos.LMARGIN, new_y=YPos.NEXT)
        self.set_text_color(*self.TXT); self.ln(2)

    def body(self, t, size=9.5, color=None):
        self.set_font("Helvetica", "", size); self.set_text_color(*(color or self.TXT))
        self.multi_cell(0, 5, t); self.ln(1)

    def table(self, headers, rows, widths, hc=None):
        hc = hc or self.DARK
        self.set_font("Helvetica", "B", 8.5); self.set_fill_color(*hc); self.set_text_color(*self.GOLD)
        for h, w in zip(headers, widths):
            self.cell(w, 7, h, fill=True, align="C")
        self.ln()
        self.set_font("Helvetica", "", 8.5)
        for ri, row in enumerate(rows):
            # estimate height by wrapping
            self.set_fill_color(245, 247, 250) if ri % 2 == 0 else self.set_fill_color(255, 255, 255)
            self.set_text_color(*self.TXT)
            for val, w in zip(row, widths):
                self.cell(w, 6.2, clean(str(val)), fill=True, align="C")
            self.ln()
        self.ln(2)

    def resource(self, r):
        """Render one resource as a compact card with personalized 'why'."""
        pri = r.get("priority", "Recommended")
        pc = self.PRI.get(pri, self.PRI["Recommended"])
        name = clean(r.get("name", ""))
        prov = clean(r.get("provider", ""))
        rtype = clean(r.get("rtype", ""))
        cost = clean(r.get("cost", ""))
        lvl = clean(r.get("level", ""))
        why = clean(r.get("why", ""))

        # measure 'why' height to keep card together / page-break cleanly
        self.set_font("Helvetica", "", 8)
        lines = self.multi_cell(176, 4.2, why, dry_run=True, output="LINES")
        why_h = 4.2 * max(1, len(lines))
        card_h = 9 + why_h + 3
        if self.get_y() + card_h > 285:
            self.add_page()

        x0 = self.l_margin; y0 = self.get_y()
        # priority strip
        self.set_fill_color(*pc); self.rect(x0, y0, 2.2, card_h - 2, "F")
        # priority badge
        self.set_xy(x0 + 4, y0)
        self.set_font("Helvetica", "B", 6.8); self.set_fill_color(*pc); self.set_text_color(*self.WHITE)
        bw = 17
        self.cell(bw, 4, pri.upper(), fill=True, align="C")
        # name
        self.set_xy(x0 + 4 + bw + 2, y0 - 0.3)
        self.set_font("Helvetica", "B", 9.3); self.set_text_color(*self.DARK)
        self.cell(0, 4.6, name[:78])
        # provider / type / cost / level line
        self.set_xy(x0 + 4 + bw + 2, y0 + 4.2)
        self.set_font("Helvetica", "", 7.6); self.set_text_color(*self.MID)
        meta = prov
        if rtype: meta += "  -  " + rtype
        self.cell(0, 4, meta[:95])
        # cost + level on right-ish, next line
        self.set_xy(x0 + 4, y0 + 8.3)
        self.set_font("Helvetica", "B", 7.8); self.set_text_color(*self.BLUE)
        self.cell(0, 4, clean(cost) + "    |    Level " + lvl)
        # why
        self.set_xy(x0 + 4, y0 + 8.3 + 4.4)
        self.set_font("Helvetica", "I", 8); self.set_text_color(60, 65, 75)
        self.set_x(x0 + 4)
        self.multi_cell(178, 4.2, why)
        # bottom divider
        yend = self.get_y() + 1
        self.set_draw_color(225, 228, 233); self.set_line_width(0.2)
        self.line(x0, yend, 210 - self.r_margin, yend)
        self.set_y(yend + 1.5)

