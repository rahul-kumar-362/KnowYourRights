        self.multi_cell(178,4.8,clean(text))
        self.set_y(y0+ht+3)

    def board(self,fen,caption,shaded=None,moveline=""):
        shaded=shaded or set()
        m=fen_map(fen) if "/" in fen else fen  # allow dict
        sq=10.3; bsz=8*sq
        need=bsz+ (10 if not moveline else 16) + 8
        if self.get_y()+need>280: self.add_page()
        bx=self.l_margin+(190-bsz)/2+2; by=self.get_y()+2
        for r in range(8):
            rank=8-r
            for c in range(8):
                name="abcdefgh"[c]+str(rank)
                x=bx+c*sq; y=by+r*sq
                if name in shaded: self.set_fill_color(*self.HL)
                else: self.set_fill_color(*(self.LIGHTSQ if (r+c)%2==0 else self.DARKSQ))
                self.rect(x,y,sq,sq,"F")
                pc=m.get(name)
                if pc:
                    cx=x+sq/2; cy=y+sq/2; rad=sq*0.39
                    if pc.isupper():
                        self.set_fill_color(252,252,250); self.set_draw_color(25,25,25)
                    else:
                        self.set_fill_color(38,38,44); self.set_draw_color(8,8,8)
                    self.set_line_width(0.3); self.ellipse(cx-rad,cy-rad,2*rad,2*rad,"FD")
                    self.set_text_color(*((20,20,20) if pc.isupper() else (248,248,248)))
                    self.set_font("Helvetica","B",13)
                    self.set_xy(x,cy-2.7); self.cell(sq,5,pc.upper(),align="C")
        self.set_draw_color(40,40,40); self.set_line_width(0.4); self.rect(bx,by,bsz,bsz)
        self.set_font("Helvetica","",7); self.set_text_color(*self.MID)
        for c in range(8):
            self.set_xy(bx+c*sq,by+bsz+0.6); self.cell(sq,3.5,"abcdefgh"[c],align="C")
        for r in range(8):
            self.set_xy(bx-4.2,by+r*sq+sq/2-2); self.cell(4,4,str(8-r),align="C")
        self.set_xy(self.l_margin,by+bsz+4.5)
        if moveline:
            self.set_font("Helvetica","B",9.3); self.set_text_color(*self.ACC)
            self.set_x(self.l_margin)
            self.multi_cell(184,4.5,clean(moveline),align="C")
        self.set_font("Helvetica","I",9); self.set_text_color(*self.MID)
        self.set_x(self.l_margin)
        self.multi_cell(184,4.5,clean("Diagram: "+caption),align="C")
        self.set_y(self.get_y()+3); self.set_text_color(*self.INK)

