def clean(s):
    if s is None: return ""
    s=str(s)
    rep={"—":"-","–":"-","−":"-","‘":"'","’":"'","“":'"',"”":'"',
         "…":"...","•":"-"," ":" ","€":"EUR ","é":"e","ü":"u","ö":"o","½":"1/2"}
    for k,v in rep.items(): s=s.replace(k,v)
    return "".join(ch if ord(ch)<256 else "?" for ch in s)

def fen_map(fen):
    m={}
    for r,row in enumerate(fen.split()[0].split("/")):
        rank=8-r; col=0
        for ch in row:
            if ch.isdigit(): col+=int(ch)
            else: m["abcdefgh"[col]+str(rank)]=ch; col+=1
    return m

