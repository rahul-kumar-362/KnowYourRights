from fpdf import FPDF
from fpdf.enums import XPos, YPos

class ChessRoadmapPDF(FPDF):

    DARK_BG    = (15, 23, 42)
    GOLD       = (212, 175, 55)
    GOLD_LIGHT = (255, 215, 80)
    WHITE      = (255, 255, 255)
    LIGHT_BG   = (245, 247, 250)
    SECTION_BG = (30, 41, 59)
    TEXT_DARK  = (30, 30, 30)
    TEXT_MID   = (71, 85, 105)
    GREEN      = (34, 197, 94)
    RED        = (239, 68, 68)
    BLUE       = (59, 130, 246)
    AMBER      = (245, 158, 11)
    PHASE_COLORS = [
        (59, 130, 246),
        (34, 197, 94),
        (245, 158, 11),
        (168, 85, 247),
    ]

    def header(self):
        if self.page_no() == 1:
            return
        self.set_fill_color(*self.DARK_BG)
        self.rect(0, 0, 210, 12, "F")
        self.set_font("Helvetica", "B", 8)
        self.set_text_color(*self.GOLD)
        self.set_xy(0, 3)
        self.cell(210, 6, "SCRODINGER -- GRANDMASTER ROADMAP 2026", align="C")
        self.set_text_color(*self.TEXT_DARK)

    def footer(self):
        if self.page_no() == 1:
            return
        self.set_y(-12)
        self.set_fill_color(*self.DARK_BG)
        self.rect(0, self.get_y(), 210, 12, "F")
        self.set_font("Helvetica", "", 7)
        self.set_text_color(*self.GOLD)
        self.cell(0, 8,
            "Page " + str(self.page_no()) + "  |  Prepared June 2026  |  Based on chess.com & lichess.org profile analysis",
            align="C")
        self.set_text_color(*self.TEXT_DARK)

    def h1(self, text):
        self.set_font("Helvetica", "B", 20)
        self.set_text_color(*self.GOLD)
        self.ln(4)
        self.cell(0, 10, text, new_x=XPos.LMARGIN, new_y=YPos.NEXT)
        self.set_draw_color(*self.GOLD)
        self.set_line_width(0.6)
        self.line(self.l_margin, self.get_y(), 210 - self.r_margin, self.get_y())
        self.ln(3)
        self.set_text_color(*self.TEXT_DARK)

    def h2(self, text, color=None):
        color = color or self.SECTION_BG
        self.ln(3)
        y = self.get_y()
        self.set_fill_color(*color)
        self.rect(self.l_margin, y, 190, 8, "F")
        self.set_font("Helvetica", "B", 11)
        self.set_text_color(*self.WHITE)
        self.set_xy(self.l_margin + 3, y + 1)
        self.cell(0, 6, text, new_x=XPos.LMARGIN, new_y=YPos.NEXT)
        self.set_text_color(*self.TEXT_DARK)
        self.ln(2)

    def h3(self, text, color=None):
        color = color or self.GOLD
        self.set_font("Helvetica", "B", 10)
        self.set_text_color(*color)
        self.cell(0, 6, text, new_x=XPos.LMARGIN, new_y=YPos.NEXT)
        self.set_text_color(*self.TEXT_DARK)
        self.ln(1)

    def body(self, text, size=9.5):
        self.set_font("Helvetica", "", size)
        self.set_text_color(*self.TEXT_DARK)
        self.multi_cell(0, 5, text)
        self.ln(1)

    def bullet(self, items, indent=5):
        self.set_font("Helvetica", "", 9.5)
        self.set_text_color(*self.TEXT_DARK)
        for item in items:
            self.set_x(self.l_margin + indent)
            self.cell(5, 5.5, "-")
            self.multi_cell(0, 5.5, item)
        self.ln(1)

    def numbered(self, items, indent=5):
        self.set_font("Helvetica", "", 9.5)
        self.set_text_color(*self.TEXT_DARK)
        for i, item in enumerate(items, 1):
            self.set_x(self.l_margin + indent)
            self.cell(6, 5.5, str(i) + ".")
            self.multi_cell(0, 5.5, item)
        self.ln(1)

    def simple_table(self, headers, rows, col_widths, header_color=None, stripe=True):
        hc = header_color or self.DARK_BG
        self.set_font("Helvetica", "B", 9)
        self.set_fill_color(*hc)
        self.set_text_color(*self.GOLD)
        for h, w in zip(headers, col_widths):
            self.cell(w, 7, h, border=0, fill=True, align="C")
        self.ln()
        self.set_font("Helvetica", "", 9)
        for ri, row in enumerate(rows):
            if stripe:
                if ri % 2 == 0:
                    self.set_fill_color(245, 247, 250)
                else:
                    self.set_fill_color(255, 255, 255)
            self.set_text_color(*self.TEXT_DARK)
            for val, w in zip(row, col_widths):
                self.cell(w, 6.5, str(val), border=0, fill=stripe, align="C")
            self.ln()
        self.ln(3)

    def phase_box(self, number, title, target, color):
        y = self.get_y()
        w = 190
        self.set_fill_color(*color)
        self.rect(self.l_margin, y, w, 10, "F")
        self.set_font("Helvetica", "B", 14)
        self.set_text_color(*self.WHITE)
        self.set_xy(self.l_margin + 2, y + 1)
        self.cell(12, 8, "0" + str(number))
        self.set_font("Helvetica", "B", 11)
        self.set_xy(self.l_margin + 16, y + 2)
        self.cell(100, 6, title)
        self.set_font("Helvetica", "B", 8)
        self.set_fill_color(255, 255, 255)
        self.set_text_color(*color)
        bw = 65
        self.rect(self.l_margin + w - bw - 2, y + 2, bw, 6, "F")
        self.set_xy(self.l_margin + w - bw - 2, y + 2)
        self.cell(bw, 6, "TARGET: " + target, align="C")
        self.set_text_color(*self.TEXT_DARK)
        self.ln(12)

    def info_box(self, text, color):
        self.set_fill_color(*color)
        self.set_text_color(*self.WHITE)
        y = self.get_y()
        self.rect(self.l_margin, y, 190, 1.5, "F")
        self.set_x(self.l_margin + 3)
        self.set_font("Helvetica", "B", 9.5)
        self.multi_cell(184, 6, text)
        self.set_fill_color(*color)
        self.rect(self.l_margin, self.get_y(), 190, 1.5, "F")
        self.ln(4)
        self.set_text_color(*self.TEXT_DARK)

    def stat_card(self, label, value, sub, x, y, w=44, color=None):
        color = color or self.BLUE
        self.set_fill_color(*self.LIGHT_BG)
        self.rect(x, y, w, 22, "F")
        self.set_fill_color(*color)
        self.rect(x, y, w, 3, "F")
        self.set_font("Helvetica", "B", 14)
        self.set_text_color(*color)
        self.set_xy(x, y + 4)
        self.cell(w, 8, value, align="C")
        self.set_font("Helvetica", "B", 7.5)
        self.set_text_color(*self.TEXT_DARK)
        self.set_xy(x, y + 12)
        self.cell(w, 4, label, align="C")
        self.set_font("Helvetica", "", 7)
        self.set_text_color(*self.TEXT_MID)
        self.set_xy(x, y + 16)
        self.cell(w, 4, sub, align="C")
        self.set_text_color(*self.TEXT_DARK)


