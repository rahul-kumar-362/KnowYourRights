"""
Phase 7 — Web Calculator (Streamlit)
Bedside hand recovery prediction tool for stroke clinicians.
Run with: streamlit run webapp/app.py
"""

import streamlit as st
import pandas as pd
import numpy as np
import pickle
import json
from pathlib import Path
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches

BASE = Path(__file__).parent.parent
MODELS_DIR = BASE / "models"
METRICS = BASE / "results" / "metrics"

# ── load best model (Random Forest — best external validation AUC) ──
@st.cache_resource
def load_model():
    with open(MODELS_DIR / "random_forest.pkl", "rb") as f:
        return pickle.load(f)

@st.cache_data
def load_top5():
    with open(METRICS / "top5_predictors.json") as f:
        return json.load(f)

model = load_model()
top5 = load_top5()

# ── page config ────────────────────────────────────────────────────
st.set_page_config(
    page_title="StrokeHand Predictor",
    page_icon="🧠",
    layout="wide"
)

# ── header ─────────────────────────────────────────────────────────
st.title("StrokeHand Recovery Predictor")
st.markdown(
    "**ML-based prediction of hand function recovery at 3 months after acute ischemic stroke**  \n"
    "Enter patient data collected within 72h of stroke onset. "
    "Output: probability of achieving ARAT ≥32 (good hand function)."
)
st.markdown("---")

# ── input form ────────────────────────────────────────────────────
col1, col2, col3 = st.columns(3)

with col1:
    st.subheader("Demographics")
    age = st.number_input("Age (years)", 18, 100, 65)
    sex = st.selectbox("Sex", ["Male", "Female"])
    handedness = st.selectbox("Handedness", ["Right", "Left"])
    htn = st.selectbox("Hypertension", ["Yes", "No"])
    dm = st.selectbox("Diabetes", ["Yes", "No"])
    af = st.selectbox("Atrial Fibrillation", ["Yes", "No"])
    time_assess = st.slider("Time to assessment (hours)", 1.0, 72.0, 24.0, 0.5)

with col2:
    st.subheader("NIHSS Scores")
    nihss_total = st.slider("NIHSS Total Score", 0, 30, 8)
    nihss_motor = st.slider("NIHSS Motor Arm (0-4)", 0, 4, 2)
    nihss_consc = st.selectbox("NIHSS Consciousness impaired", ["No (0)", "Yes (1)"])
    nihss_sens  = st.slider("NIHSS Sensory (0-2)", 0, 2, 1)
    nihss_negl  = st.slider("NIHSS Neglect (0-2)", 0, 2, 0)
    st.subheader("Clinical")
    safe_score = st.slider("SAFE Score (0-10)", 0, 10, 5,
                            help="Shoulder Abduction (0-5) + Finger Extension (0-5)")
    finger_ext = st.selectbox("Finger Extension present", ["Yes", "No"])
    tct = st.slider("Trunk Control Test (0-100)", 0, 100, 70)

with col3:
    st.subheader("CT Scan (NCCT)")
    aspects = st.slider("ASPECTS Score (0-10)", 0, 10, 8,
                         help="Higher = less damage")
    cst = st.selectbox("CST Involvement", ["No", "Yes"],
                        help="Corticospinal tract involvement on CT")
    lesion_vol = st.number_input("Lesion Volume (mL/cc)", 0.0, 200.0, 15.0, step=0.5)
    lesion_side = st.selectbox("Lesion Side", ["Left", "Right"])

# ── predict ────────────────────────────────────────────────────────
st.markdown("---")

def encode(val, true_val="Yes"):
    return 1 if val == true_val else 0

input_data = pd.DataFrame([{
    "age": age,
    "sex": encode(sex, "Male"),
    "handedness": encode(handedness, "Right"),
    "hypertension": encode(htn),
    "diabetes": encode(dm),
    "atrial_fibrillation": encode(af),
    "time_to_assess_hr": time_assess,
    "nihss_total": nihss_total,
    "nihss_motor_arm": nihss_motor,
    "nihss_consciousness": encode(nihss_consc, "Yes (1)"),
    "nihss_sensory": nihss_sens,
    "nihss_neglect": nihss_negl,
    "safe_score": safe_score,
    "finger_extension": encode(finger_ext),
    "trunk_control_test": tct,
    "aspects": aspects,
    "cst_involved": encode(cst),
    "lesion_volume_cc": lesion_vol,
    "lesion_side": encode(lesion_side, "Right"),
}])

if st.button("Predict Recovery", type="primary", use_container_width=True):
    prob = model.predict_proba(input_data)[0][1]
    pct = prob * 100

    # Risk category
    if prob >= 0.75:
        category, color, advice = "HIGH likelihood of good recovery", "#2ecc71", \
            "Patient likely to achieve functional hand use. Consider standard rehabilitation pathway."
    elif prob >= 0.45:
        category, color, advice = "INTERMEDIATE — uncertain outcome", "#f39c12", \
            "Uncertain prognosis. Consider intensive early rehabilitation and close monitoring."
    else:
        category, color, advice = "LOW likelihood of good recovery", "#e74c3c", \
            "Poor prognosis for hand function. Prioritise compensatory strategies and caregiver training."

    # Result display
    rcol1, rcol2 = st.columns([1, 2])
    with rcol1:
        st.markdown(f"""
        <div style='background:{color}22; border-left:5px solid {color};
                    padding:20px; border-radius:8px; text-align:center;'>
            <h1 style='color:{color}; margin:0'>{pct:.0f}%</h1>
            <p style='font-size:13px; color:{color}; margin:4px 0'>
                Probability of ARAT ≥ 32 at 3 months
            </p>
            <p style='font-size:14px; font-weight:bold; color:{color}'>{category}</p>
            <p style='font-size:12px; color:#555'>{advice}</p>
        </div>
        """, unsafe_allow_html=True)

    with rcol2:
        # Gauge chart
        fig, ax = plt.subplots(figsize=(6, 3), subplot_kw={"aspect": "equal"})
        ax.set_xlim(-1.2, 1.2); ax.set_ylim(-0.1, 1.2)
        ax.axis("off")
        # Background arc
        theta = np.linspace(np.pi, 0, 200)
        ax.plot(np.cos(theta), np.sin(theta), lw=18, color="#eeeeee",
                solid_capstyle="butt")
        # Colored arc (up to prob)
        theta_fill = np.linspace(np.pi, np.pi - prob * np.pi, 200)
        ax.plot(np.cos(theta_fill), np.sin(theta_fill), lw=18, color=color,
                solid_capstyle="butt")
        ax.text(0, 0.35, f"{pct:.0f}%", ha="center", va="center",
                fontsize=32, fontweight="bold", color=color)
        ax.text(0, 0.05, "Predicted Probability", ha="center", va="center",
                fontsize=10, color="#555")
        ax.text(-1.0, -0.05, "0%", ha="center", fontsize=9, color="#999")
        ax.text(1.0,  -0.05, "100%", ha="center", fontsize=9, color="#999")
        ax.text(0, 1.1, "Good Recovery (ARAT >= 32)", ha="center", fontsize=9, color="#333")
        st.pyplot(fig, use_container_width=True)
        plt.close()

    # Top 5 predictor reference
    st.markdown("---")
    st.subheader("Key Predictors (from SHAP analysis)")
    t5df = pd.DataFrame(top5, columns=["Feature", "Mean |SHAP|"])
    t5df.index = range(1, 6)
    t5df["Mean |SHAP|"] = t5df["Mean |SHAP|"].round(4)
    st.table(t5df)

    st.caption(
        "Model: Random Forest trained on 350-patient Indian stroke cohort.  "
        "Validation AUC=0.915. This tool is for clinical decision support only — "
        "not a substitute for clinical judgement. TRIPOD-AI compliant."
    )
