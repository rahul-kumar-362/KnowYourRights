import time
import os
from coinbase.websocket import WSClient

def on_message(msg):
    print("Received message from server:", msg)

# Initialize WSClient pointing to our malicious local server
client = WSClient(
    api_key="my_fake_api_key", 
    api_secret="my_fake_api_secret", 
    base_url="wss://localhost:8765",
    on_message=on_message
)

print("Opening connection to wss://localhost:8765...")
client.open()
print("Subscribing to user channel...")
client.subscribe(["BTC-USD"], ["user"])

time.sleep(2)
client.close()
