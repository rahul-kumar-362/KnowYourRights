[build-system]
requires = ["setuptools>=61"]
build-backend = "setuptools.build_meta"

[project]
name = "bbscan"
version = "0.1.0"
description = "High-signal, AST-based security scanner for responsible disclosure"
readme = "README.md"
requires-python = ">=3.10"
dependencies = []

[project.optional-dependencies]
# The core local-scan path is stdlib-only. These extras enable optional features.
remote = []                 # GitHub fetching uses stdlib urllib; nothing required
report = ["PyYAML>=6"]      # optional YAML scope/rules config (JSON fallback otherwise)
dev = ["pytest>=7"]
sast = ["bandit", "semgrep"] # optional external engines, cross-checked into one model

[project.scripts]
bbscan = "scanner.cli:main"

[tool.setuptools.packages.find]
where = ["."]
include = ["scanner*"]
namespaces = false

[tool.pytest.ini_options]
testpaths = ["tests"]
markers = ["e2e: end-to-end test against a cloned target repo"]
