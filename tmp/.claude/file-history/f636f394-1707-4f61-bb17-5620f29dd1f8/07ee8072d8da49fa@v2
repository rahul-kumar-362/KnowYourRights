import pytest

from scanner.engine import scan_path
from tests._helpers import FIX, marker_lines

RULE = "PY-SEC-001"


def test_flags_hardcoded_secret():
    fx = FIX / "secrets" / "vuln_hardcoded_secret.py"
    hits = [f for f in scan_path(fx) if f.rule_id == RULE]
    assert [h.line for h in hits] == marker_lines(fx, RULE)


@pytest.mark.parametrize(
    "name", ["safe_env_var.py", "safe_placeholder.py", "safe_constant_name.py"]
)
def test_safe_secret_fixtures_are_silent(name):
    assert [f for f in scan_path(FIX / "secrets" / name) if f.rule_id == RULE] == []
