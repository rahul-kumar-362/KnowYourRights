"""Regression suite: every class of false positive the legacy scanners emitted
must produce ZERO findings here. This file is the proof of improvement.
"""

import pytest

from scanner.engine import scan_source


@pytest.mark.parametrize(
    "code",
    [
        # "verify=False" mentioned in a comment — legacy matched the substring
        "import ssl\n# never use verify=False in production\nctx = ssl.create_default_context()\n",
        # "verify=False" inside a string literal
        "msg = 'set verify=False to disable checks'\n",
        # placeholder API key in example code
        "api_key = 'YOUR_KEY_HERE'\n",
        # secret read from the environment (not a hardcoded literal)
        "import os\napi_secret = os.environ['CB_SECRET']\n",
        # a version string — legacy flagged "Version Information"
        "VERSION = 'v1.2.3'\n",
    ],
)
def test_legacy_false_positive_classes_are_silent(code):
    assert scan_source(code, "fp.py") == []


@pytest.mark.parametrize(
    "substr",
    ["verify=False", "api_key=", "YOUR_KEY_HERE", "v1.2.3", "SECURITY.md"],
)
def test_security_tokens_inside_string_literals_never_flagged(substr):
    assert scan_source(f"s = {substr!r}\n", "lit.py") == []
